# Application Settings
APP_NAME=TherapyCompanion.AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ENCRYPTION_KEY=your-encryption-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
# SQLite (local dev, no Docker needed â€” tables auto-created on startup):
DATABASE_URL=sqlite:///./therapy_dev.db
# PostgreSQL (run: docker-compose up -d):
# DATABASE_URL=postgresql://therapy_user:therapy_password@localhost:5432/virtual_therapist
REDIS_URL=redis://localhost:6379/0

# AI Providers
# ANTHROPIC_API_KEY — primary provider for all text generation (summaries, chat, twin profile).
# OPENAI_API_KEY    — used only for Whisper audio transcription.
# In production the app refuses to start with a placeholder ANTHROPIC_API_KEY.
ANTHROPIC_API_KEY=REPLACE_WITH_YOUR_ANTHROPIC_KEY
OPENAI_API_KEY=REPLACE_WITH_YOUR_OPENAI_KEY   # only needed for audio transcription

# Model routing (env-var driven; defaults shown below — update when new models release)
AI_FAST_MODEL=claude-haiku-4-5-20251001
AI_STANDARD_MODEL=claude-sonnet-4-6-20250929
AI_DEEP_MODEL=claude-opus-4-6-20251101

TEMPERATURE=0.7
MAX_TOKENS=2000

# Audio Settings
MAX_AUDIO_SIZE_MB=25
SUPPORTED_AUDIO_FORMATS=mp3,wav,m4a,ogg

# Data Privacy & Security
DATA_REGION=IL  # Israel/EU servers only
ENABLE_ENCRYPTION=True
ENABLE_AUDIT_LOG=True
GDPR_COMPLIANT=True

# Message Approval
REQUIRE_THERAPIST_APPROVAL=True
AUTO_APPROVE_TIMEOUT_HOURS=24

# Session Settings
SESSION_SUMMARY_AUTO_SAVE=True
SESSION_SUMMARY_BACKUP=True

# Hebrew Language
DEFAULT_LANGUAGE=he
RTL_SUPPORT=True

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/therapy_companion.log
