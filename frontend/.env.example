# API URL
VITE_API_URL=http://localhost:8000/api/v1

# Google OAuth (public client ID — safe to expose, required for Google Sign-In button)
# Must be prefixed with VITE_ so Vite inlines it at build time.
# In Vercel: Settings → Environment Variables → Name: VITE_GOOGLE_CLIENT_ID
VITE_GOOGLE_CLIENT_ID=
